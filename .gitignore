# SQLite database is generated by load_to_sqlite.py from the CSV --
# no need to version a regenerable binary file.
service_ops.db

# Debug log from local dashboard testing, not part of the project.
streamlit_log.txt

# Standard Python cache/bytecode.
__pycache__/
*.pyc

# config.toml (toolbar/theme settings) IS tracked -- Streamlit Cloud reads it
# straight from the repo. Only secrets.toml (API keys, credentials) is
# ignored, since that file should never be committed.
.streamlit/secrets.toml
